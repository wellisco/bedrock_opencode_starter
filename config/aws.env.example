# Copy to config/aws.env and fill in your values.
# config/aws.env is gitignored and stays on your machine only.

# Disable AWS CLI pager (less is not installed in the dev container)
AWS_PAGER=

# Option 1: Access keys
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Option 2: Named profile (required by Pi when using aws configure; default profile name is "default")
AWS_PROFILE=default

# Region for Bedrock (must match where models are enabled)
AWS_REGION=us-east-1

# Pi on Bedrock (used by ./run-pi.sh)
# PI_PROVIDER=amazon-bedrock
# PI_MODEL=us.anthropic.claude-sonnet-4-6

# Claude Code on Bedrock (used by ./run-claude.sh)
# CLAUDE_CODE_USE_BEDROCK=1
# ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-6
# ANTHROPIC_DEFAULT_OPUS_MODEL=us.anthropic.claude-opus-4-8
# ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
# ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-6
